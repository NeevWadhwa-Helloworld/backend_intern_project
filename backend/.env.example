# Server Settings
PORT=5000
NODE_ENV=development

# Database Settings
MONGODB_URI=mongodb://localhost:27017/task_db

# Security Settings
JWT_SECRET=your_super_secret_jwt_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d
COOKIE_EXPIRES_IN=7

# CORS & Frontend Origins
FRONTEND_URL=http://localhost:5173

# Gmail SMTP (for registration OTP)
# Use a Gmail App Password if 2FA is enabled: https://myaccount.google.com/apppasswords
SMTP_EMAIL=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password
